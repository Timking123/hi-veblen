{
  "name": "admin-backend",
  "version": "1.0.0",
  "description": "后台管理系统后端服务 - 个人作品集网站",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/app.js",
    "start:prod": "pm2 start ecosystem.config.js --env production",
    "stop": "pm2 stop admin-backend",
    "restart": "pm2 restart admin-backend",
    "reload": "pm2 reload admin-backend",
    "logs": "pm2 logs admin-backend",
    "monit": "pm2 monit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:init": "ts-node src/database/init.ts",
    "check:consistency": "ts-node src/scripts/checkConsistency.ts",
    "sync:files": "ts-node src/scripts/syncFiles.ts",
    "fix:encoding": "ts-node src/scripts/fixEncoding.ts",
    "migrate:up": "ts-node src/database/migrations/001_create_file_sync_log.ts"
  },
  "keywords": [
    "admin",
    "backend",
    "express",
    "sqlite",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.2",
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/exceljs": "^0.5.3",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.16",
    "@types/sql.js": "^1.4.9",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "fast-check": "^3.15.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
